generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             Int       @id
  username       String?
  firstName      String?
  lastName       String?
  balance        Decimal   @default(0) @db.Decimal(18, 6)
  totalDeposit   Decimal   @default(0) @db.Decimal(18, 6)
  totalWithdraw  Decimal   @default(0) @db.Decimal(18, 6)
  totalWon       Decimal   @default(0) @db.Decimal(18, 6)
  totalLost      Decimal   @default(0) @db.Decimal(18, 6)
  referralCode   String    @unique @default(cuid())
  referredBy     Int?
  referrer       User?     @relation("Referrals", fields: [referredBy], references: [id])
  referrals      User[]    @relation("Referrals")
  isBanned        Boolean   @default(false)
  isAdmin        Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  bets           Bet[]
  deposits       Deposit[]
  withdrawals    Withdrawal[]
  referralEarnings ReferralEarning[]
}

model Bet {
  id         String   @id @default(cuid())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  game       GameType
  betAmount  Decimal  @db.Decimal(18, 6)
  winAmount  Decimal  @default(0) @db.Decimal(18, 6)
  multiplier Decimal  @default(0) @db.Decimal(10, 4)
  status     BetStatus @default(PENDING)
  gameData   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Deposit {
  id              String        @id @default(cuid())
  userId          Int
  user            User          @relation(fields: [userId], references: [id])
  cryptoBotInvoiceId String?   @unique
  amount          Decimal       @db.Decimal(18, 6)
  amountUSDT      Decimal       @db.Decimal(18, 6)
  currency        String        @default("USDT")
  status          PaymentStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Withdrawal {
  id         String        @id @default(cuid())
  userId     Int
  user       User          @relation(fields: [userId], references: [id])
  amount     Decimal       @db.Decimal(18, 6)
  currency   String        @default("USDT")
  address    String?
  status     PaymentStatus @default(PENDING)
  adminNote  String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model ReferralEarning {
  id        String   @id @default(cuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  fromId    Int
  amount    Decimal  @db.Decimal(18, 6)
  createdAt DateTime @default(now())
}

model CrashGame {
  id         String   @id @default(cuid())
  multiplier Decimal  @db.Decimal(10, 4)
  seed       String
  createdAt  DateTime @default(now())
}

enum GameType {
  MINER
  CRASH
  COINFLIP
  LADDER
  TOWER
  SLOTS_DOG
  SLOTS_SUGAR
}

enum BetStatus {
  PENDING
  WON
  LOST
  CASHOUT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}
